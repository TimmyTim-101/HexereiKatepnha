<Application x:Class="HexereiKatepnha.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />

                <ResourceDictionary Source="/Resources/ViewMapping.xaml"></ResourceDictionary>

                <ResourceDictionary Source="/Resources/Styles/Font.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/ScrollBar.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/Button.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/Divider.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/Textblock.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/TextBox.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/TabControl.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/CheckBox.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/ListBox.xaml"></ResourceDictionary>
                <ResourceDictionary Source="/Resources/Styles/ToolTip.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>