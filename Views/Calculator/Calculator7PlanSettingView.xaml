<UserControl x:Class="HexereiKatepnha.Views.Calculator.Calculator7PlanSettingView"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:HexereiKatepnha.Models.ModelsForViews.Calculator"
             xmlns:vm="clr-namespace:HexereiKatepnha.ViewModels.Calculator"
             d:DataContext="{d:DesignInstance vm:Calculator7PlanSettingViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource GlobalBackColor}"
             d:DesignHeight="1080" d:DesignWidth="1720"
             FontFamily="{StaticResource MyFont}">
    <UserControl.Resources>
        <DataTemplate x:Key="PlanItemTemplate" DataType="{x:Type models:Calculator7PlanSettingModel}">
            <Border CornerRadius="5" BorderBrush="White" BorderThickness="1" Margin="2" Height="68">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="150"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Index}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Grid Grid.Column="1">
                        <Image Source="{Binding StarBackgroundImagePath}" Width="60" Height="60" Stretch="UniformToFill"></Image>
                        <Image Source="{Binding ImagePath}" Width="60" Height="60" Stretch="UniformToFill"></Image>
                        <Image Source="{Binding ElementImagePath}" Width="15" Height="15" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"></Image>
                    </Grid>
                    <TextBlock Grid.Column="2" Text="{Binding Name}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Border Grid.Column="3" Style="{StaticResource VerticalDivider}"></Border>
                    <TextBlock Grid.Column="4" Text="{Binding LevelString}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Border Grid.Column="5" Style="{StaticResource VerticalDivider}"></Border>
                    <TextBlock Grid.Column="6" Text="{Binding TalentAString}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Border Grid.Column="7" Style="{StaticResource VerticalDivider}"></Border>
                    <TextBlock Grid.Column="8" Text="{Binding TalentEString}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Border Grid.Column="9" Style="{StaticResource VerticalDivider}"></Border>
                    <TextBlock Grid.Column="10" Text="{Binding TalentQString}" Style="{StaticResource MyTextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                    <Border Grid.Column="11" Style="{StaticResource VerticalDivider}"></Border>
                    <Border Grid.Column="12" CornerRadius="5" BorderThickness="1" BorderBrush="#1AFFFFFF" Margin="5" Width="50">
                        <Button Style="{StaticResource ImageButton}" Command="{Binding DataContext.ClickOnTopCommand, ElementName=RootControl}" CommandParameter="{Binding Id}" Width="50" Height="50">
                            <Image Source="../Calculator/../../Resources/Icons/vertical_align_top_30dp_DDDDDD_FILL0_wght400_GRAD0_opsz24.png" Stretch="Uniform" Width="30" Height="30"></Image>
                        </Button>
                    </Border>
                    <Border Grid.Column="13" CornerRadius="5" BorderThickness="1" BorderBrush="#1AFFFFFF" Margin="5" Width="50">
                        <Button Style="{StaticResource ImageButton}" Command="{Binding DataContext.ClickOnUpCommand, ElementName=RootControl}" CommandParameter="{Binding Id}" Width="50" Height="50">
                            <Image Source="../Calculator/../../Resources/Icons/arrow_circle_up_30dp_DDDDDD_FILL0_wght400_GRAD0_opsz24.png" Stretch="Uniform" Width="30" Height="30"></Image>
                        </Button>
                    </Border>
                    <Border Grid.Column="14" CornerRadius="5" BorderThickness="1" BorderBrush="#3AFFFFFF" Margin="5" Width="50">
                        <Button Style="{StaticResource ImageButton}" Command="{Binding DataContext.ClickOnDownCommand, ElementName=RootControl}" CommandParameter="{Binding Id}" Width="50" Height="50">
                            <Image Source="../Calculator/../../Resources/Icons/arrow_circle_down_30dp_DDDDDD_FILL0_wght400_GRAD0_opsz24.png" Stretch="Uniform" Width="30" Height="30"></Image>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="{DynamicResource GlobalBackColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30,20,30,5">
            <TextBlock Text="规划设置" Style="{StaticResource MyTextBlock}" FontSize="30"></TextBlock>
            <Button Style="{StaticResource ImageButton}" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Margin="10,0,0,0" Command="{Binding OpenHelpWebPageCommand}">
                <Image Source="/Resources/Icons/help_30dp_DDDDDD_FILL0_wght400_GRAD0_opsz24.png" Height="30" Width="30" Stretch="UniformToFill"></Image>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="帮助"></ToolTip>
                </Button.ToolTip>
            </Button>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
        <ListBox Grid.Row="2" Style="{StaticResource ModernListBox}" ItemsSource="{Binding PlanList}" ItemTemplate="{StaticResource PlanItemTemplate}" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" Padding="15,2">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical"></VirtualizingStackPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</UserControl>