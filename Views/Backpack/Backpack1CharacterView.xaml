<UserControl x:Class="HexereiKatepnha.Views.Backpack.Backpack1CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:models="clr-namespace:HexereiKatepnha.Models.ModelsForViews.Backpack"
             xmlns:vm="clr-namespace:HexereiKatepnha.ViewModels.Backpack"
             d:DataContext="{d:DesignInstance vm:Backpack1CharacterViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource GlobalBackColor}"
             d:DesignHeight="1080" d:DesignWidth="1720"
             FontFamily="{StaticResource MyFont}">
    <UserControl.Resources>
        <DataTemplate x:Key="CharacterCardTemplate" DataType="{x:Type models:Backpack1CharacterModel}">
            <Button Command="{Binding DataContext.ClickOnCharacterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Margin="2" Padding="0">
                <Border CornerRadius="5" BorderBrush="White" BorderThickness="1" Cursor="Hand" Background="Transparent">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Image Source="{Binding BackgroundImagePath}" Width="120" Height="120" Stretch="UniformToFill"></Image>
                            <Image Source="{Binding ImagePath}" Width="120" Height="120" Stretch="UniformToFill"></Image>
                            <Image Source="{Binding ElementImagePath}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"></Image>
                        </Grid>
                        <Viewbox Grid.Row="1" MaxWidth="115" StretchDirection="DownOnly" Margin="0,2">
                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"></TextBlock>
                        </Viewbox>
                        <TextBlock Grid.Row="2" Style="{StaticResource MyTextBlock}" Text="{Binding LevelNameString}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCCCCC"></TextBlock>
                        <UniformGrid Grid.Row="3" Rows="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="A" FontSize="14" Foreground="#333333"></TextBlock>
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding TalentAString}" FontSize="14" Foreground="#CCCCCC"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="E" FontSize="14" Foreground="#333333"></TextBlock>
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding TalentEString}" FontSize="14" Foreground="#CCCCCC"></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="Q" FontSize="14" Foreground="#333333"></TextBlock>
                                <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding TalentQString}" FontSize="14" Foreground="#CCCCCC"></TextBlock>
                            </StackPanel>
                        </UniformGrid>
                        <UniformGrid Grid.Row="4" Rows="1">
                            <Image Source="{Binding AscensionPropertyDictionary[1].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[1]}"></Image>
                            <Image Source="{Binding AscensionPropertyDictionary[2].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[2]}"></Image>
                            <Image Source="{Binding AscensionPropertyDictionary[3].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[3]}"></Image>
                            <Image Source="{Binding AscensionPropertyDictionary[4].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[4]}"></Image>
                            <Image Source="{Binding AscensionPropertyDictionary[5].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[5]}"></Image>
                            <Image Source="{Binding AscensionPropertyDictionary[6].ImagePath, IsAsync=True}" Width="18" Height="18" Stretch="UniformToFill" Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding AscensionOpacityList[6]}"></Image>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="{DynamicResource GlobalBackColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="角色" Style="{StaticResource MyTextBlock}" FontSize="30" Margin="30,20,30,5" />
        <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="15,0,0,0">
                    <Border BorderBrush="White" BorderThickness="1" CornerRadius="5" Margin="2">
                        <WrapPanel Orientation="Horizontal">
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="1" Margin="2">
                                <Image Source="{Binding Element1ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="火"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="2" Margin="2">
                                <Image Source="{Binding Element2ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="水"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="2">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="3" Margin="2">
                                <Image Source="{Binding Element3ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="风"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="3">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="4" Margin="2">
                                <Image Source="{Binding Element4ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="雷"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="4">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="5" Margin="2">
                                <Image Source="{Binding Element5ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="草"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="5">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="6" Margin="2">
                                <Image Source="{Binding Element6ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="冰"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="6">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="7" Margin="2">
                                <Image Source="{Binding Element7ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="岩"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementFilter}" Value="7">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <Border BorderBrush="White" BorderThickness="1" CornerRadius="5" Margin="2">
                        <WrapPanel Orientation="Horizontal">
                            <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="1" Margin="2">
                                <Image Source="{Binding Weapon1ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="单手剑"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeaponFilter}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="2" Margin="2">
                                <Image Source="{Binding Weapon2ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="双手剑"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeaponFilter}" Value="2">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="3" Margin="2">
                                <Image Source="{Binding Weapon3ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="长柄武器"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeaponFilter}" Value="3">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="4" Margin="2">
                                <Image Source="{Binding Weapon4ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="法器"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeaponFilter}" Value="4">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="5" Margin="2">
                                <Image Source="{Binding Weapon5ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                    <Image.ToolTip>
                                        <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="弓"></ToolTip>
                                    </Image.ToolTip>
                                </Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeaponFilter}" Value="5">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <Border BorderBrush="White" BorderThickness="1" CornerRadius="5" Margin="2">
                        <WrapPanel Orientation="Horizontal">
                            <Button Command="{Binding ClickOnStarFilterCommand}" CommandParameter="4" Margin="2">
                                <Image Source="{Binding Star4ImagePath}" Stretch="Uniform" Width="55" Height="14" Margin="10,30"></Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StarFilter}" Value="4">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding ClickOnStarFilterCommand}" CommandParameter="5" Margin="2">
                                <Image Source="{Binding Star5ImagePath}" Stretch="Uniform" Width="55" Height="14" Margin="10,30"></Image>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StarFilter}" Value="5">
                                                <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                    </Border>
                    <CheckBox Content="隐藏白板角色" IsChecked="{Binding IsHideLowLevelCharacter}" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource ModernCheckBoxStyle}" Margin="5"></CheckBox>
                </WrapPanel>
                <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
                <ui:ItemsRepeaterScrollHost Grid.Row="2">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewer}">
                        <ui:ItemsRepeater ItemsSource="{Binding CharacterView}" ItemTemplate="{StaticResource CharacterCardTemplate}" Margin="15,0,0,0">
                            <ui:ItemsRepeater.Layout>
                                <ui:UniformGridLayout Orientation="Horizontal"></ui:UniformGridLayout>
                            </ui:ItemsRepeater.Layout>
                        </ui:ItemsRepeater>
                    </ScrollViewer>
                </ui:ItemsRepeaterScrollHost>
            </Grid>
            <Border Grid.Column="1" Style="{StaticResource VerticalDivider}"></Border>
            <TabControl Grid.Column="2" ItemContainerStyle="{StaticResource ModernTabItemStyle}" Width="441">
                <TabControl.Style>
                    <Style TargetType="TabControl" BasedOn="{StaticResource ModernTabControlStyle}">
                        <Setter Property="Visibility" Value="Visible"></Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCharacter}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"></Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Style>
                <TabItem Header="面板展示">
                    <Border CornerRadius="5" BorderBrush="White" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Image Source="{Binding SelectedCharacter.BackgroundImagePath}" Width="240" Height="240" Stretch="UniformToFill"></Image>
                                    <Image Source="{Binding SelectedCharacter.ImagePath, IsAsync=True}" Width="240" Height="240" Stretch="UniformToFill"></Image>
                                    <Image Source="{Binding SelectedCharacter.ElementImagePath, IsAsync=True}" Width="60" Height="60" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"></Image>
                                </Grid>
                                <Border Grid.Column="1" Style="{StaticResource VerticalDivider}"></Border>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding SelectedCharacter.ElementImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5"></Image>
                                        <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,5" FontSize="18"></TextBlock>
                                    </StackPanel>
                                    <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
                                    <ToggleButton Grid.Row="2" x:Name="LevelToggleButton" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding IsLevelPopupOpen, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <ContentPresenter></ContentPresenter>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent">
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="等级：" Foreground="#AAAAAA" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.LevelNameString}" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        </StackPanel>
                                    </ToggleButton>
                                    <Popup Grid.Row="2" IsOpen="{Binding IsLevelPopupOpen}" PlacementTarget="{Binding ElementName=LevelToggleButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                        <Border Background="#FF2D2D30" BorderBrush="#555555" BorderThickness="1" CornerRadius="5" Padding="5" Margin="0,5,0,0">
                                            <UniformGrid Rows="10" Columns="11">
                                                <Button Style="{StaticResource TextButton}" Content="1" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="1"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="2" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="2"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="3" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="3"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="4" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="4"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="5" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="5"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="6" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="6"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="7" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="7"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="8" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="8"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="9" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="9"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="10" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="10"></Button>
                                                <Border Background="Transparent" Width="30" Height="30" Margin="2"></Border>
                                                <Button Style="{StaticResource TextButton}" Content="11" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="11"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="12" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="12"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="13" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="13"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="14" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="14"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="15" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="15"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="16" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="16"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="17" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="17"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="18" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="18"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="19" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="19"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="20" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="20"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="20+" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="21"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="21" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="22"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="22" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="23"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="23" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="24"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="24" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="25"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="25" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="26"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="26" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="27"></Button>
                                                <Button Style="{StaticResource TextButton}" Content="27" Width="30" Height="30" Margin="2" Command="{Binding ClickOnLevelSelectionCommand}" CommandParameter="28"></Button>
