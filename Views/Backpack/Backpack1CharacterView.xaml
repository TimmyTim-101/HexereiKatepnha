<UserControl x:Class="HexereiKatepnha.Views.Backpack.Backpack1CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:HexereiKatepnha.Models.ModelsForViews.Backpack"
             xmlns:vm="clr-namespace:HexereiKatepnha.ViewModels.Backpack"
             d:DataContext="{d:DesignInstance vm:Backpack1CharacterViewModel}"
             mc:Ignorable="d"
             Background="#FF1E1E1E"
             d:DesignHeight="1080" d:DesignWidth="1720"
             FontFamily="{StaticResource MyFont}">
    <Grid Background="{DynamicResource GlobalBackColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="角色" Style="{StaticResource MyTextBlock}" FontSize="30" Margin="30,20,30,5" />
        <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <WrapPanel Orientation="Horizontal" Margin="15,0,0,0">
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="1" Margin="2">
                            <Image Source="{Binding Element1ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="火"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="2" Margin="2">
                            <Image Source="{Binding Element2ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="水"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="2">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="3" Margin="2">
                            <Image Source="{Binding Element3ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="风"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="3">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="4" Margin="2">
                            <Image Source="{Binding Element4ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="雷"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="4">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="5" Margin="2">
                            <Image Source="{Binding Element5ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="草"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="5">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="6" Margin="2">
                            <Image Source="{Binding Element6ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="冰"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="6">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnElementFilterCommand}" CommandParameter="7" Margin="2">
                            <Image Source="{Binding Element7ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="岩"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementFilter}" Value="7">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal" Margin="15,0,0,0">
                        <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="1" Margin="2">
                            <Image Source="{Binding Weapon1ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="单手剑"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeaponFilter}" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="2" Margin="2">
                            <Image Source="{Binding Weapon2ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="双手剑"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeaponFilter}" Value="2">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="3" Margin="2">
                            <Image Source="{Binding Weapon3ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="长柄武器"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeaponFilter}" Value="3">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="4" Margin="2">
                            <Image Source="{Binding Weapon4ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="法器"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeaponFilter}" Value="4">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ClickOnWeaponFilterCommand}" CommandParameter="5" Margin="2">
                            <Image Source="{Binding Weapon5ImagePath}" Stretch="Uniform" Width="55" Height="55" Margin="10" ToolTipService.InitialShowDelay="100">
                                <Image.ToolTip>
                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="弓"></ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ImageButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeaponFilter}" Value="5">
                                            <Setter Property="Background" Value="{DynamicResource GlobalSelectedColor}"></Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
                <ListBox Grid.Row="2" ItemsSource="{Binding CharacterView}" SelectedItem="{Binding SelectedCharacter, Mode=TwoWay}" Style="{StaticResource ModernListBox}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="15,0,0,0"></WrapPanel>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Backpack1CharacterModel}">
                            <Border Margin="2" CornerRadius="5" BorderBrush="White" BorderThickness="1" Cursor="Hand">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding BackgroundImagePath, IsAsync=True}" Width="120" Height="120" Stretch="UniformToFill"></Image>
                                        <Image Source="{Binding ImagePath, IsAsync=True}" Width="120" Height="120" Stretch="UniformToFill"></Image>
                                        <Image Source="{Binding ElementImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"></Image>
                                    </Grid>
                                    <Viewbox Grid.Row="1" MaxWidth="115" StretchDirection="DownOnly" Margin="0,2">
                                        <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"></TextBlock>
                                    </Viewbox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            <Border Grid.Column="1" Style="{StaticResource VerticalDivider}"></Border>
            <TabControl Grid.Column="2" Style="{StaticResource ModernTabControlStyle}" ItemContainerStyle="{StaticResource ModernTabItemStyle}" Width="441">
                <TabItem Header="面板展示">
                    <Border CornerRadius="5" BorderBrush="White" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Image Source="{Binding SelectedCharacter.BackgroundImagePath, IsAsync=True}" Width="240" Height="240" Stretch="UniformToFill"></Image>
                                    <Image Source="{Binding SelectedCharacter.ImagePath, IsAsync=True}" Width="240" Height="240" Stretch="UniformToFill"></Image>
                                    <Image Source="{Binding SelectedCharacter.ElementImagePath, IsAsync=True}" Width="60" Height="60" Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"></Image>
                                </Grid>
                                <Border Grid.Column="1" Style="{StaticResource VerticalDivider}"></Border>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="Auto"></RowDefinition>
                                        <RowDefinition Height="*"></RowDefinition>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image Source="{Binding SelectedCharacter.ElementImagePath, IsAsync=True}" Width="25" Height="25" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,5"></Image>
                                        <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,5" FontSize="18"></TextBlock>
                                    </StackPanel>
                                    <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" Cursor="Hand">
                                        <TextBlock Style="{StaticResource MyTextBlock}" Text="等级：" Foreground="#AAAAAA" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.LevelString}" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                    <Border Grid.Row="3" Style="{StaticResource HorizontalDivider}"></Border>
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"></ColumnDefinition>
                                            <ColumnDefinition Width="*"></ColumnDefinition>
                                            <ColumnDefinition Width="*"></ColumnDefinition>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Image Source="{Binding SelectedCharacter.TalentPropertyDictionary[1].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.TalentPropertyDictionary[1].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.TalentAString}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Image Source="{Binding SelectedCharacter.TalentPropertyDictionary[2].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.TalentPropertyDictionary[2].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.TalentEString}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Vertical" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Image Source="{Binding SelectedCharacter.TalentPropertyDictionary[3].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.TalentPropertyDictionary[3].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.TalentQString}" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="5" Style="{StaticResource HorizontalDivider}"></Border>
                                    <Grid Grid.Row="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"></RowDefinition>
                                            <RowDefinition Height="Auto"></RowDefinition>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand">
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="命之座：" Foreground="#AAAAAA" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                            <TextBlock Style="{StaticResource MyTextBlock}" Text="{Binding SelectedCharacter.CharacterConfigModel.Ascension}" Margin="2,5" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                        </StackPanel>
                                        <UniformGrid Grid.Row="1" Rows="1">
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[1].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[1]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[1].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[2].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[2]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[2].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[3].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[3]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[3].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[4].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[4]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[4].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[5].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[5]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[5].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                            <Image Source="{Binding SelectedCharacter.AscensionPropertyDictionary[6].ImagePath, IsAsync=True}" Width="30" Height="30" Stretch="UniformToFill" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTipService.InitialShowDelay="100" Opacity="{Binding SelectedCharacter.AscensionOpacityList[6]}">
                                                <Image.ToolTip>
                                                    <ToolTip Style="{StaticResource FlutterStyleToolTip}" Content="{Binding SelectedCharacter.AscensionPropertyDictionary[6].Description}"></ToolTip>
                                                </Image.ToolTip>
                                            </Image>
                                        </UniformGrid>
                                    </Grid>
                                </Grid>
                            </Grid>
                            <Border Grid.Row="1" Style="{StaticResource HorizontalDivider}"></Border>
                            <TextBlock Grid.Row="2" Style="{StaticResource TodoTextBlock}" Text="武器 &amp; 圣遗物 &amp; 评分"></TextBlock>
                            <Border Grid.Row="3" Style="{StaticResource HorizontalDivider}"></Border>
                            <TextBlock Grid.Row="4" Style="{StaticResource TodoTextBlock}" Text="面板详细信息"></TextBlock>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="培养目标">
                    <TextBlock Style="{StaticResource TodoTextBlock}" Text="培养目标"></TextBlock>
                </TabItem>
                <TabItem Header="面板目标">
                    <TextBlock Style="{StaticResource TodoTextBlock}" Text="面板目标"></TextBlock>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>